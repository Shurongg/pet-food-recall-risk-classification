# Data files (keep .gitkeep, ignore everything else)
data/raw/*
data/interim/*
data/processed/*
data/embeddings/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/embeddings/.gitkeep

# Model binaries
models/classifiers/*
models/selected/*
!models/classifiers/.gitkeep
!models/selected/.gitkeep

